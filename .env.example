# Core
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://*.railway.app

# Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgres://mandi:mandi@localhost:5432/mandiconnect

# Redis (Railway provides REDIS_URL automatically)
REDIS_URL=redis://localhost:6379/0

# Email (console backend in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@mandiconnect.local
FRONTEND_BASE_URL=http://localhost:8000

# Celery (falls back to REDIS_URL if unset)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Listing expiry window (days)
LISTING_STALE_DAYS=3

# --- Local dev without Redis ---
# Set both to True to run the app with NO Redis/worker running:
#   - cache falls back to in-memory (otherwise the API 500s on throttling)
#   - Celery tasks run inline instead of queuing on Redis
USE_LOCMEM_CACHE=True
CELERY_TASK_ALWAYS_EAGER=True

# For a quick local run without Postgres, use SQLite instead of the line above:
# DATABASE_URL=sqlite:///db.sqlite3
